# Copy this file to .env for local development.
# Never commit credentials or real secrets.

# Application
APP_ENV=development
APP_URL=http://localhost:3000
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# Supabase — backend only
SUPABASE_URL=
