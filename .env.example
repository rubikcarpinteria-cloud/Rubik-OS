# Copy this file to .env for local development.
# Never commit credentials or real secrets.

# Application
# Use development, test, staging or production.
# APP_ENV=staging must use https://uqdyknsvvqutuefixgmb.supabase.co.
APP_ENV=development
APP_URL=http://localhost:3000
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# Supabase staging - backend only.
# Keep SUPABASE_SERVICE_ROLE_KEY only in secure backend environments.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Supabase - safe public values exposed by Vite.
# Do not put service_role or private keys in VITE_* variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:3001

# External integrations
OPENAI_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
